<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- https://developer.android.google.cn/develop/ui/views/launch/splash-screen?hl=zh-cn#splash-screen-animate-reqs -->
    <style name="Theme.EasterEggs.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation
        duration. -->
        <item name="windowSplashScreenBackground">@color/md_theme_background</item>
        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated
             drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_anim_cinnamon_bun_platlogo</item>
        <!-- Required for animated icons. -->
        <item name="windowSplashScreenAnimationDuration">500</item>
        <!-- Set the theme of the Activity that directly follows your splash
        screen. This is required. -->
        <item name="postSplashScreenTheme">@style/Theme.EasterEggs</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
    </style>

    <style name="Theme.EasterEggs.Starting.Android16" parent="Theme.EasterEggs.Starting">
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_anim_baklava_platlogo</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
    </style>

    <style name="Theme.EasterEggs.Starting.Android15" parent="Theme.EasterEggs.Starting">
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_anim_v_platlogo</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.EasterEggs" parent="Theme.AppColors">
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
    </style>

</resources>
