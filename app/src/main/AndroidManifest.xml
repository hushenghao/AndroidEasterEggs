<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:dede="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    dede:once="🍃">

    <uses-permission android:name="android.permission.INTERNET"/>

    <uses-permission
        android:name="com.android.launcher.permission.INSTALL_SHORTCUT"
        android:maxSdkVersion="26" />

    <application
        android:name=".EasterEggsApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/backup_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_config_old"
        android:icon="@mipmap/ic_launcher_17"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_17_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EasterEggs"
        tools:targetApi="tiramisu">

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="com.dede.android_eggs.startup.ApplicationInitializer"
                android:value="androidx.startup" />
        </provider>

        <activity
            android:name=".views.main.EasterEggsActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.EasterEggs.Starting"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <!-- egg://easter_egg/api/26 -->
                <data
                    android:host="easter_egg"
                    android:scheme="egg" />

                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".views.main.Android16SplashActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.EasterEggs.Starting.Android16"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".views.main.Android15SplashActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@style/Theme.EasterEggs.Starting.Android15"
            android:windowSoftInputMode="adjustResize" />

        <!-- Proxy activities for retaining easter egg tasks in recents.
             Each stub has a unique taskAffinity (manifest declarative, OEM reliable).
             retainInRecents is set at runtime via FLAG_ACTIVITY_RETAIN_IN_RECENTS,
             because android:retainInRecents is not a public manifest attribute.
             LRU reuse, max 5 tasks. -->
        <activity
            android:name=".views.main.util.EggProxyActivity0"
            android:exported="false"
            android:taskAffinity="com.dede.android_eggs.egg.stub0"
            android:theme="@android:style/Theme.NoDisplay" />
        <activity
            android:name=".views.main.util.EggProxyActivity1"
            android:exported="false"
            android:taskAffinity="com.dede.android_eggs.egg.stub1"
            android:theme="@android:style/Theme.NoDisplay" />
        <activity
            android:name=".views.main.util.EggProxyActivity2"
            android:exported="false"
            android:taskAffinity="com.dede.android_eggs.egg.stub2"
            android:theme="@android:style/Theme.NoDisplay" />
        <activity
            android:name=".views.main.util.EggProxyActivity3"
            android:exported="false"
            android:taskAffinity="com.dede.android_eggs.egg.stub3"
            android:theme="@android:style/Theme.NoDisplay" />
        <activity
            android:name=".views.main.util.EggProxyActivity4"
            android:exported="false"
            android:taskAffinity="com.dede.android_eggs.egg.stub4"
            android:theme="@android:style/Theme.NoDisplay" />

        <activity-alias
            android:name=".Android17IconAlias"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_17"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_17_round"
            android:targetActivity=".views.main.EasterEggsActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name=".Android16IconAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_16"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_16_round"
            android:targetActivity=".views.main.Android16SplashActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <activity-alias
            android:name=".Android15IconAlias"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_15"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_15_round"
            android:targetActivity=".views.main.Android15SplashActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>
    </application>

</manifest>
