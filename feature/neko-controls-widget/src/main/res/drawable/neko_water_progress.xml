<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/neko_widget_card_corner_radius" />
            <solid android:color="@color/neko_water_progress_background_color" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip android:clipOrientation="horizontal" android:gravity="start">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/neko_widget_card_corner_radius" />
                <solid android:color="@color/neko_water_progress_color" />
            </shape>
        </clip>
    </item>
</layer-list>
